#--------------------------------------------------------------------
# Example Environment Configuration file
#
# This file can be used as a starting point for your own
# custom .env files, and contains most of the possible settings
# available in a default install.
#
# By default, all of the settings are commented out. If you want
# to override the setting, you must un-comment it by removing the '#'
# at the beginning of the line.
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------

CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'http://localhost:8080'
# If you have trouble with `.`, you could also use `_`.
# app_baseURL = ''
# app.forceGlobalSecureRequests = false
# app.CSPEnabled = false

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------

database.default.hostname = localhost
database.default.database = healthsphere
database.default.username = root
database.default.password =
database.default.DBDriver = MySQLi
# database.default.DBPrefix =
# database.default.port = 3306

# If you use MySQLi as tests, first update the values of Config\Database::$tests.
# database.tests.hostname = localhost
# database.tests.database = ci4_test
# database.tests.username = root
# database.tests.password = root
# database.tests.DBDriver = MySQLi
# database.tests.DBPrefix =
# database.tests.charset = utf8mb4
# database.tests.DBCollat = utf8mb4_general_ci
# database.tests.port = 3306

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------

# encryption.key =

#--------------------------------------------------------------------
# JWT CONFIGURATION
#--------------------------------------------------------------------

JWT_SECRET = 'your-super-secret-256-bit-key-change-this-in-production'
JWT_ACCESS_EXPIRY = 3600       # Access token expiry in seconds (1 hour)
JWT_REFRESH_EXPIRY = 172800    # Refresh token expiry in seconds (2 days)

#--------------------------------------------------------------------
# COOKIE CONFIGURATION
#--------------------------------------------------------------------

COOKIE_DOMAIN = ''
COOKIE_PATH = '/'
COOKIE_PREFIX = ''
COOKIE_SECURE = false          # Set to true in production (HTTPS only)
COOKIE_HTTPONLY = true         # Prevents JavaScript access to cookies
COOKIE_SAMESITE = 'Lax'        # CSRF protection (Lax, Strict, or None)

#--------------------------------------------------------------------
# EMAIL / SMTP (uncomment and set for production)
#--------------------------------------------------------------------
#SMTP_HOST = 'smtp.example.com'
#SMTP_PORT = 587
#SMTP_USER = 'smtp-user@example.com'
#SMTP_PASS = 'super-secret-password'
#SMTP_FROM = 'no-reply@example.com'
#SMTP_FROM_NAME = 'HealthSphere'
#MAIL_DRIVER = 'smtp' # or 'mail'


#--------------------------------------------------------------------
# FEATURE FLAGS
#--------------------------------------------------------------------

FEATURES_SUBSCRIPTION_ENABLED = false       # Enable subscription logic
FEATURES_ADMIN_DELEGATION_ENABLED = false   # Enable User Admin system

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------

# session.driver = 'CodeIgniter\Session\Handlers\FileHandler'
# session.savePath = null

#--------------------------------------------------------------------
# LOGGER
#--------------------------------------------------------------------

# logger.threshold = 4

#--------------------------------------------------------------------
# WEBSOCKET CONFIGURATION
#--------------------------------------------------------------------

WS_HOST = 'ws://localhost'
WS_PORT = 8084
WS_SECRET = 'healthsphere_ws_secret_change_in_production'

#--------------------------------------------------------------------
# ML/AI SERVICE CONFIGURATION
#--------------------------------------------------------------------

ML_SERVICE_HOST = 'http://localhost:8000'
ML_SERVICE_API_KEY = 'your-ml-service-api-key'

#--------------------------------------------------------------------
# OTP CONFIGURATION
#--------------------------------------------------------------------

OTP_TTL = 300  # OTP validity in seconds (5 minutes)
